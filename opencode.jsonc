// OpenCode project configuration for 入梦 Agent workflow.
// Profile: glm-5
// Model: fcloud-glm-5/glm-5
{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "dream-runner",
  "model": "fcloud-minimax-m3/minimax-m3",
  "permission": {
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "edit": "allow",
    "task": "allow",
    "bash": "allow",
    "external_directory": "deny",
    "doom_loop": "deny",
    "webfetch": "deny",
    "websearch": "deny"
  },
  "share": "manual"
}
