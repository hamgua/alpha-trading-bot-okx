// OpenCode project configuration for 入梦 Agent workflow.
// Profile: minimax-m3
// Model: token-share/minimax-m3
{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "dream-runner",
  "model": "token-share/minimax-m3",
  "permission": {
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "edit": "allow",
    "task": "allow",
    "bash": "allow",
    "external_directory": "deny",
    "doom_loop": "deny",
    "webfetch": "deny",
    "websearch": "deny"
  },
  "share": "manual"
}
